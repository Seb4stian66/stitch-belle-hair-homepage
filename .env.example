# Konfigurationsdatei für das Backend
# Wird automatisch durch 'npm run setup' aus kunden_daten.json generiert.
# Manuell befüllen falls nötig, dann als .env speichern.

# Webserver Port
PORT=3000

# Google Places API Key (NUR für Backend-Bewertungen - niemals im Frontend verwenden)
GOOGLE_API_KEY=DEIN_GOOGLE_PLACES_API_KEY_HIER
GOOGLE_PLACE_ID=DEINE_GOOGLE_PLACE_ID_HIER
